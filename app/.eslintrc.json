{
  "extends": ["airbnb-base"],
  "env": {
    "node": true,
    "es6": true
  },
  "rules": {
    "no-console": ["warn", { "allow": ["warn", "error", "info"] }],
    "no-param-reassign": ["error", { "props": false }],
    "strict": "off",
    "indent": ["error", 4, { "SwitchCase": 1 }],
    "arrow-parens": ["error", "as-needed"],
    "import/no-extraneous-dependencies": ["error", { "packageDir": ["./", "./app"] }]
  }
}
