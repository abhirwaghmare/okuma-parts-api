  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'When summarizing this conversation, structure the summary in these four sections as precise pointers without losing context. Categorize by importance.\n\n## What was done\n- Completed tasks and outcomes\n\n## What is going on\n- Current phase, active agent, task in progress, any blockers\n\n## What to do next\n- Remaining phases, pending tasks, next steps\n\n## Active plan and conventions\n- Plan summary, patterns being followed, key decisions made, file paths involved'"
          }
        ]
      }
    ]
  }
